{
  "name": "The Next Step",
  "slug": "the-next-step",
  "description": "Meeting summary specialist. Extracts action items with owners, due dates, notes, and next steps from any meeting transcript. No fluff — just what needs to happen and who's doing it.",
  "goal": "Turn messy meeting transcripts into structured action plans. Every meeting has a next step — this agent finds it.",
  "decision_logic": "Route incoming requests to the appropriate handler: meeting-summary produces a full structured breakdown (summary, action items, decisions, participants). action-items produces only the lightweight action list for fast extraction. sentiment analyzes the meeting tone. All handlers use Claude Haiku with meeting-specialist system prompts enforcing the standard: task (owner) due date / notes / next step (owner).",
  "agent_type": "reactive",
  "auth_type": "none",
  "rate_type": "per_call",
  "rate_amount": 0.002,
  "tags": ["meetings", "action-items", "summary", "productivity", "nlp", "claude"],
  "capability_schema": {
    "capabilities": [
      {
        "id": "signalpot/meeting-summary@v1",
        "name": "Meeting Summary",
        "description": "Produces a full structured meeting summary: overview, action items with owners/due dates/notes/next steps, decisions made, and participants mentioned.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": { "type": "string", "minLength": 50, "maxLength": 50000, "description": "Meeting transcript, notes, or minutes" },
            "context": { "type": "string", "maxLength": 500, "description": "Optional context about the meeting (e.g. 'Weekly engineering standup')" }
          },
          "required": ["text"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "summary": { "type": "string", "description": "2-3 sentence meeting overview" },
            "action_items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "task": { "type": "string" },
                  "owner": { "type": "string" },
                  "due": { "type": "string" },
                  "notes": { "type": "string" },
                  "next_step": { "type": "string" }
                },
                "required": ["task", "owner"]
              }
            },
            "decisions": { "type": "array", "items": { "type": "string" } },
            "participants": { "type": "array", "items": { "type": "string" } },
            "meeting_tone": { "type": "string", "enum": ["productive", "tense", "collaborative", "unfocused", "urgent"] }
          },
          "required": ["summary", "action_items", "decisions", "participants", "meeting_tone"]
        }
      },
      {
        "id": "signalpot/action-items@v1",
        "name": "Action Item Extraction",
        "description": "Lightweight extraction of just the action items from a meeting transcript. Fast and cheap.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": { "type": "string", "minLength": 20, "maxLength": 50000, "description": "Meeting transcript, notes, or minutes" }
          },
          "required": ["text"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "action_items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "task": { "type": "string" },
                  "owner": { "type": "string" },
                  "due": { "type": "string" },
                  "notes": { "type": "string" },
                  "next_step": { "type": "string" }
                },
                "required": ["task", "owner"]
              }
            },
            "count": { "type": "integer" }
          },
          "required": ["action_items", "count"]
        }
      },
      {
        "id": "signalpot/sentiment@v1",
        "name": "Meeting Tone Analysis",
        "description": "Analyzes the emotional tone of a meeting — productive, tense, collaborative, etc.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": { "type": "string", "minLength": 1, "maxLength": 10000 }
          },
          "required": ["text"]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "sentiment": { "type": "string", "enum": ["positive", "negative", "neutral", "mixed"] },
            "score": { "type": "number", "minimum": -1, "maximum": 1 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "meeting_tone": { "type": "string" },
            "emotions": {
              "type": "object",
              "properties": {
                "joy": { "type": "number" },
                "anger": { "type": "number" },
                "sadness": { "type": "number" },
                "fear": { "type": "number" },
                "surprise": { "type": "number" }
              }
            }
          },
          "required": ["sentiment", "score", "confidence", "meeting_tone"]
        }
      }
    ]
  }
}
